# Скопируйте в `.env` и задайте свои значения.

DATABASE_URL=sqlite:///./exam_system.db
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
# Тестовая среда: exam_test + демо база знаний + teacher/student@test.local (пароль testtest12)
# SEED_TEST_ENV=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://localhost

# Docker Compose dev (frontend): прокси Vite — см. vite.config.js и docker-compose.dev.yml
# VITE_API_BASE_URL=/api
# DOCKER_BACKEND_PROXY=http://backend:8000

# LLM (OpenAI-совместимый API). OpenRouter через ProxyAPI:
# OPENAI_BASE_URL=https://api.proxyapi.ru/openrouter/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=mistralai/mistral-medium-3.1
# Опционально: отдельная модель только для оценки ответов (эталон vs студент). Пусто = OPENAI_MODEL
# OPENAI_SCORING_MODEL=
# Эмбеддинги для векторного поиска (384 dim). Лёгкая по умолчанию в config — при необходимости:
# EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Если OPENAI_API_KEY не задан, клиент может использовать GigaChat:
GIGACHAT_CREDENTIALS=

# Пропустить проверку LLM при старте (офлайн)
# LLM_SKIP_STARTUP_CHECK=false

# Docker Compose (PostgreSQL)
POSTGRES_PASSWORD=exam
